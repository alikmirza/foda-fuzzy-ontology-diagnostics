    <!-- http://foda.com/ontology/diagnostic#Prop_MemoryLeak_to_CpuSaturation -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Prop_MemoryLeak_to_CpuSaturation">
