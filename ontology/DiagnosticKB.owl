<?xml version="1.0"?>
<rdf:RDF xmlns="http://foda.com/ontology/diagnostic#"
     xml:base="http://foda.com/ontology/diagnostic"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:diagnostic="http://foda.com/ontology/diagnostic#">
    <owl:Ontology rdf:about="http://foda.com/ontology/diagnostic">
        <rdfs:label>FODA Diagnostic Knowledge Base</rdfs:label>
        <rdfs:comment>Ontology for representing diagnostic knowledge in distributed microservices systems</rdfs:comment>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- http://foda.com/ontology/diagnostic#affectsService -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#affectsService">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#MicroService"/>
        <rdfs:label>affects service</rdfs:label>
        <rdfs:comment>Relates a fault to the service it affects</rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#causedBy -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#causedBy">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#RootCause"/>
        <rdfs:label>caused by</rdfs:label>
        <rdfs:comment>Links a fault to its root cause</rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#detectedBy -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#detectedBy">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Anomaly"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#MLModel"/>
        <rdfs:label>detected by</rdfs:label>
        <rdfs:comment>Links anomaly to the ML model that detected it</rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#diagnosedAs -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#diagnosedAs">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Anomaly"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:label>diagnosed as</rdfs:label>
        <rdfs:comment>Links an anomaly to its diagnosed fault type</rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#hasContributingFactor -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#hasContributingFactor">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>has contributing factor</rdfs:label>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#hasDiagnosis -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#hasDiagnosis">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#MicroService"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#DiagnosticResult"/>
        <rdfs:label>has diagnosis</rdfs:label>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#hasMetric -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#hasMetric">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#MicroService"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#Metric"/>
        <rdfs:label>has metric</rdfs:label>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#hasRecommendation -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#hasRecommendation">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#Recommendation"/>
        <rdfs:label>has recommendation</rdfs:label>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#hasSeverity -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#hasSeverity">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#Severity"/>
        <rdfs:label>has severity</rdfs:label>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#hasSymptom -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#hasSymptom">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#Symptom"/>
        <rdfs:label>has symptom</rdfs:label>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#indicatesAnomaly -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#indicatesAnomaly">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Symptom"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#Anomaly"/>
        <rdfs:label>indicates anomaly</rdfs:label>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#propagationSource -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#propagationSource">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Propagation"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:label>propagation source</rdfs:label>
        <rdfs:comment>The fault type from which a typical propagation pattern originates.</rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://foda.com/ontology/diagnostic#propagationTarget -->
    <owl:ObjectProperty rdf:about="http://foda.com/ontology/diagnostic#propagationTarget">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Propagation"/>
        <rdfs:range rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:label>propagation target</rdfs:label>
        <rdfs:comment>The fault type that a typical propagation pattern manifests as downstream.</rdfs:comment>
    </owl:ObjectProperty>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- http://foda.com/ontology/diagnostic#anomalyScore -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#anomalyScore">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Anomaly"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label>anomaly score</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#confidence -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#confidence">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#DiagnosticResult"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label>confidence</rdfs:label>
        <rdfs:comment>Confidence score of the diagnosis (0.0 to 1.0)</rdfs:comment>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#description -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#description">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>description</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#diagnosticId -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#diagnosticId">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#DiagnosticResult"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>diagnostic ID</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#fci -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#fci">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#DiagnosticResult"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label>fuzzy confidence index</rdfs:label>
        <rdfs:comment>Fuzzy Confidence Index (FCI) value</rdfs:comment>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#importance -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#importance">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label>importance</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#metricName -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#metricName">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>metric name</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#metricValue -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#metricValue">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label>metric value</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#modelName -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#modelName">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#MLModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>model name</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#predictionId -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#predictionId">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Anomaly"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>prediction ID</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#serviceId -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#serviceId">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#MicroService"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>service ID</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#timestamp -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#timestamp">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label>timestamp</rdfs:label>
    </owl:DatatypeProperty>


    <!-- http://foda.com/ontology/diagnostic#propagationStrength -->
    <owl:DatatypeProperty rdf:about="http://foda.com/ontology/diagnostic#propagationStrength">
        <rdfs:domain rdf:resource="http://foda.com/ontology/diagnostic#Propagation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label>propagation strength</rdfs:label>
        <rdfs:comment>Typical strength with which the source fault propagates to the target fault. 1.0 = typical, 0.5 = sometimes/conditional, 0.0 = atypical. Values outside [0, 1] are not expected.</rdfs:comment>
    </owl:DatatypeProperty>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- http://foda.com/ontology/diagnostic#Anomaly -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#Anomaly">
        <rdfs:label>Anomaly</rdfs:label>
        <rdfs:comment>An anomalous behavior detected by ML models</rdfs:comment>
    </owl:Class>


    <!-- http://foda.com/ontology/diagnostic#ContributingFactor -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#ContributingFactor">
        <rdfs:label>Contributing Factor</rdfs:label>
        <rdfs:comment>A factor that contributes to a fault</rdfs:comment>
    </owl:Class>


    <!-- http://foda.com/ontology/diagnostic#DiagnosticResult -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#DiagnosticResult">
        <rdfs:label>Diagnostic Result</rdfs:label>
        <rdfs:comment>Result of fuzzy diagnostic analysis</rdfs:comment>
    </owl:Class>


    <!-- http://foda.com/ontology/diagnostic#Fault -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#Fault">
        <rdfs:label>Fault</rdfs:label>
        <rdfs:comment>A fault or failure condition in the system</rdfs:comment>
    </owl:Class>


    <!-- http://foda.com/ontology/diagnostic#MLModel -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#MLModel">
        <rdfs:label>ML Model</rdfs:label>
        <rdfs:comment>Machine learning model used for detection</rdfs:comment>
    </owl:Class>


    <!-- http://foda.com/ontology/diagnostic#Metric -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#Metric">
        <rdfs:label>Metric</rdfs:label>
        <rdfs:comment>A performance or health metric</rdfs:comment>
    </owl:Class>


    <!-- http://foda.com/ontology/diagnostic#MicroService -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#MicroService">
        <rdfs:label>Micro Service</rdfs:label>
        <rdfs:comment>A microservice instance in the system</rdfs:comment>
    </owl:Class>


    <!-- http://foda.com/ontology/diagnostic#Recommendation -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#Recommendation">
        <rdfs:label>Recommendation</rdfs:label>
        <rdfs:comment>Remediation recommendation for a fault</rdfs:comment>
    </owl:Class>


    <!-- http://foda.com/ontology/diagnostic#RootCause -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#RootCause">
        <rdfs:label>Root Cause</rdfs:label>
        <rdfs:comment>Underlying root cause of a fault</rdfs:comment>
    </owl:Class>


    <!-- http://foda.com/ontology/diagnostic#Severity -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#Severity">
        <rdfs:label>Severity</rdfs:label>
        <rdfs:comment>Severity level of a fault</rdfs:comment>
    </owl:Class>


    <!-- http://foda.com/ontology/diagnostic#Symptom -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#Symptom">
        <rdfs:label>Symptom</rdfs:label>
        <rdfs:comment>Observable symptom of a fault</rdfs:comment>
    </owl:Class>


    <!-- http://foda.com/ontology/diagnostic#Propagation -->
    <owl:Class rdf:about="http://foda.com/ontology/diagnostic#Propagation">
        <rdfs:label>Propagation</rdfs:label>
        <rdfs:comment>A typical propagation pattern from one fault type to another. Reified as a class because OWL annotation properties on object-property relations are awkward; each instance pins down a (source, target, strength) triple.</rdfs:comment>
    </owl:Class>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- Severity Individuals -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Low">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Severity"/>
        <rdfs:label>Low</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Medium">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Severity"/>
        <rdfs:label>Medium</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#High">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Severity"/>
        <rdfs:label>High</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Critical">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Severity"/>
        <rdfs:label>Critical</rdfs:label>
    </owl:NamedIndividual>


    <!-- Fault Type Individuals -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#ResourceContention">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:label>Resource Contention</rdfs:label>
        <description>Multiple resources experiencing high utilization simultaneously</description>
        <hasRecommendation rdf:resource="http://foda.com/ontology/diagnostic#Rec_ResourceContention"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_ResourceContention_MultiResourceUtil"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_ResourceContention_QueueLength"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#MemoryLeak">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:label>Memory Leak</rdfs:label>
        <description>Memory utilization abnormally high, may indicate a memory leak</description>
        <hasRecommendation rdf:resource="http://foda.com/ontology/diagnostic#Rec_MemoryLeak"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_MemoryLeak_HeapUtil"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_MemoryLeak_GcPressure"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CpuSaturation">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:label>CPU Saturation</rdfs:label>
        <description>CPU utilization at or near capacity</description>
        <hasRecommendation rdf:resource="http://foda.com/ontology/diagnostic#Rec_CpuSaturation"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_CpuSaturation_CpuUtil"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_CpuSaturation_RequestLatency"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#NetworkCongestion">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:label>Network Congestion</rdfs:label>
        <description>Network traffic experiencing congestion or bandwidth saturation</description>
        <hasRecommendation rdf:resource="http://foda.com/ontology/diagnostic#Rec_NetworkCongestion"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_NetworkCongestion_BandwidthUtil"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_NetworkCongestion_PacketLoss"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#HighErrorRate">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:label>High Error Rate</rdfs:label>
        <description>Error rate exceeded acceptable thresholds</description>
        <hasRecommendation rdf:resource="http://foda.com/ontology/diagnostic#Rec_HighErrorRate"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_HighErrorRate_ErrorRatio"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_HighErrorRate_DownstreamFailures"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#LatencySpike">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:label>Latency Spike</rdfs:label>
        <description>Response latency significantly increased</description>
        <hasRecommendation rdf:resource="http://foda.com/ontology/diagnostic#Rec_LatencySpike"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_LatencySpike_P99Latency"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_LatencySpike_DependencyLatency"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#ThroughputDegradation">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:label>Throughput Degradation</rdfs:label>
        <description>System throughput degraded below expected performance</description>
        <hasRecommendation rdf:resource="http://foda.com/ontology/diagnostic#Rec_ThroughputDegradation"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_ThroughputDegradation_RequestRate"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_ThroughputDegradation_ThreadStarvation"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#DiskIoBottleneck">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Fault"/>
        <rdfs:label>Disk I/O Bottleneck</rdfs:label>
        <description>Disk I/O operations experiencing bottlenecks</description>
        <hasRecommendation rdf:resource="http://foda.com/ontology/diagnostic#Rec_DiskIoBottleneck"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_DiskIoBottleneck_IoWait"/>
        <hasContributingFactor rdf:resource="http://foda.com/ontology/diagnostic#CF_DiskIoBottleneck_QueueDepth"/>
    </owl:NamedIndividual>


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Recommendation Individuals (one per fault prototype)
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Rec_CpuSaturation">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Recommendation"/>
        <rdfs:label>Remediate CPU Saturation</rdfs:label>
        <description>Scale out CPU-bound services horizontally; profile hot code paths; consider request batching or async processing to relieve CPU pressure.</description>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Rec_MemoryLeak">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Recommendation"/>
        <rdfs:label>Remediate Memory Leak</rdfs:label>
        <description>Capture a heap dump and analyse retained-object dominators; restart leaking instances and roll back recent deployments suspected of leaking references.</description>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Rec_LatencySpike">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Recommendation"/>
        <rdfs:label>Remediate Latency Spike</rdfs:label>
        <description>Inspect dependency latencies and slow query logs; enable caching for hot keys; review recent deployment changes that may have shifted call patterns.</description>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Rec_HighErrorRate">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Recommendation"/>
        <rdfs:label>Remediate High Error Rate</rdfs:label>
        <description>Triage error logs by status code; check downstream service health; apply circuit breakers and bounded retries with backoff to contain the blast radius.</description>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Rec_ResourceContention">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Recommendation"/>
        <rdfs:label>Remediate Resource Contention</rdfs:label>
        <description>Review per-pod resource quotas; stagger batch workloads; enable horizontal autoscaling on the most contended dimension (CPU, memory, or I/O).</description>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Rec_NetworkCongestion">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Recommendation"/>
        <rdfs:label>Remediate Network Congestion</rdfs:label>
        <description>Inspect link utilisation and retransmits; redistribute traffic across availability zones; raise per-pod network egress limits if saturated.</description>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Rec_ThroughputDegradation">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Recommendation"/>
        <rdfs:label>Remediate Throughput Degradation</rdfs:label>
        <description>Check thread-pool and connection-pool saturation; verify downstream rate limits; scale out stateless workers if request queueing is observed.</description>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Rec_DiskIoBottleneck">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Recommendation"/>
        <rdfs:label>Remediate Disk I/O Bottleneck</rdfs:label>
        <description>Move hot data to faster storage tiers; batch small writes; verify volume IOPS limits and increase provisioned IOPS if the disk is throttled.</description>
    </owl:NamedIndividual>


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Contributing Factor Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- CPU Saturation -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_CpuSaturation_CpuUtil">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>CPU Utilisation</rdfs:label>
        <metricName>cpu_utilization</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.9</importance>
        <description>Sustained CPU utilisation above the configured saturation threshold.</description>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_CpuSaturation_RequestLatency">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>Request Latency</rdfs:label>
        <metricName>request_latency</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.6</importance>
        <description>Elevated request latency caused by CPU run-queue queueing.</description>
    </owl:NamedIndividual>

    <!-- Memory Leak -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_MemoryLeak_HeapUtil">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>Heap Utilisation</rdfs:label>
        <metricName>heap_utilization</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.95</importance>
        <description>Heap utilisation trending upward across successive GC cycles.</description>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_MemoryLeak_GcPressure">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>GC Pressure</rdfs:label>
        <metricName>gc_pause_ratio</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.7</importance>
        <description>Ratio of time spent in stop-the-world GC pauses exceeds the SLO budget.</description>
    </owl:NamedIndividual>

    <!-- Latency Spike -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_LatencySpike_P99Latency">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>P99 Request Latency</rdfs:label>
        <metricName>p99_latency_ms</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.95</importance>
        <description>Tail (P99) request latency above the SLO ceiling.</description>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_LatencySpike_DependencyLatency">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>Dependency Call Latency</rdfs:label>
        <metricName>downstream_call_latency_ms</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.7</importance>
        <description>Outbound call latency to downstream dependencies elevated.</description>
    </owl:NamedIndividual>

    <!-- High Error Rate -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_HighErrorRate_ErrorRatio">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>5xx Error Ratio</rdfs:label>
        <metricName>error_rate</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.95</importance>
        <description>Ratio of 5xx responses to total requests above the SLO threshold.</description>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_HighErrorRate_DownstreamFailures">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>Downstream Failures</rdfs:label>
        <metricName>downstream_failure_rate</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.65</importance>
        <description>Failure rate of outbound calls to dependent services.</description>
    </owl:NamedIndividual>

    <!-- Resource Contention -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_ResourceContention_MultiResourceUtil">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>Multi-Resource Utilisation</rdfs:label>
        <metricName>combined_resource_utilization</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.9</importance>
        <description>Two or more resource dimensions (CPU, memory, I/O) simultaneously saturated.</description>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_ResourceContention_QueueLength">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>Pending Queue Length</rdfs:label>
        <metricName>pending_queue_length</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.6</importance>
        <description>Pending request or task queue length growing beyond steady-state.</description>
    </owl:NamedIndividual>

    <!-- Network Congestion -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_NetworkCongestion_BandwidthUtil">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>Bandwidth Utilisation</rdfs:label>
        <metricName>network_bandwidth_utilization</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.9</importance>
        <description>Network egress or ingress bandwidth utilisation near link capacity.</description>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_NetworkCongestion_PacketLoss">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>Packet Loss / Retransmits</rdfs:label>
        <metricName>tcp_retransmit_rate</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.65</importance>
        <description>Elevated TCP retransmit rate consistent with congestion or packet loss.</description>
    </owl:NamedIndividual>

    <!-- Throughput Degradation -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_ThroughputDegradation_RequestRate">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>Served Request Rate</rdfs:label>
        <metricName>requests_per_second</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.9</importance>
        <description>Served request rate dropped substantially below the rolling baseline.</description>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_ThroughputDegradation_ThreadStarvation">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>Thread Pool Starvation</rdfs:label>
        <metricName>thread_pool_active_ratio</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.6</importance>
        <description>Thread pool consistently at maximum active count, indicating starvation.</description>
    </owl:NamedIndividual>

    <!-- Disk I/O Bottleneck -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_DiskIoBottleneck_IoWait">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>I/O Wait Time</rdfs:label>
        <metricName>io_wait_percent</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.9</importance>
        <description>Sustained CPU I/O wait time above the configured threshold.</description>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#CF_DiskIoBottleneck_QueueDepth">
        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#ContributingFactor"/>
        <rdfs:label>Disk Queue Depth</rdfs:label>
        <metricName>disk_queue_depth</metricName>
        <metricValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</metricValue>
        <importance rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.65</importance>
        <description>Block-device queue depth growing beyond its provisioned IOPS budget.</description>
    </owl:NamedIndividual>


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Propagation patterns (22 typical fault-to-fault propagations)
    //
    // Each Propagation individual reifies the triple
    //   (propagationSource, propagationTarget, propagationStrength)
    // for a typical fault-propagation pattern. Strength 1.0 = a
    // pattern that almost always co-occurs with the source fault;
    // 0.5 = a pattern that conditionally co-occurs. Ordered pairs
    // not listed have implicit strength 0.0.
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- Strength 1.0 — typical propagation patterns -->


    <!-- http://foda.com/ontology/diagnostic#Prop_CpuSaturation_to_LatencySpike -->
    <owl:NamedIndividual rdf:about="http://foda.com/ontology/diagnostic#Prop_CpuSaturation_to_LatencySpike">
