        <propagationStrength rdf:datatype="http://www.w3.org/2001/XMLSchema#double">1.0</propagationStrength>
        <rdfs:label>CpuSaturation → LatencySpike</rdfs:label>
    </owl:NamedIndividual>


    <!-- http://foda.com/ontology/diagnostic#Prop_CpuSaturation_to_ThroughputDegradation -->
