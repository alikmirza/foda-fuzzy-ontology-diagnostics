        <rdf:type rdf:resource="http://foda.com/ontology/diagnostic#Propagation"/>
        <propagationSource rdf:resource="http://foda.com/ontology/diagnostic#HighErrorRate"/>
        <propagationTarget rdf:resource="http://foda.com/ontology/diagnostic#LatencySpike"/>
        <propagationStrength rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.5</propagationStrength>
        <rdfs:label>HighErrorRate → LatencySpike</rdfs:label>
