        <propagationTarget rdf:resource="http://foda.com/ontology/diagnostic#ThroughputDegradation"/>
        <propagationStrength rdf:datatype="http://www.w3.org/2001/XMLSchema#double">1.0</propagationStrength>
        <rdfs:label>CpuSaturation → ThroughputDegradation</rdfs:label>
    </owl:NamedIndividual>


